{
  "name": "scraper-epub",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "ONE_PORT_DEV=1 node apps/api/src/server.js",
    "build:web": "npm --workspace @scraper-epub/web run build",
    "build": "npm run build:web",
    "start": "node apps/api/src/server.js"
  },
  "devDependencies": {
    "vite": "^5.4.21"
  }
}
