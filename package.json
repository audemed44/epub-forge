{
  "name": "epub-forge",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cross-env ONE_PORT_DEV=1 tsx apps/api/src/server.ts",
    "build:web": "npm --workspace @epub-forge/web run build",
    "build": "npm run build:web",
    "start": "tsx apps/api/src/server.ts",
    "typecheck": "npm --workspace @epub-forge/core run typecheck && npm --workspace @epub-forge/api run typecheck && npm --workspace @epub-forge/web run typecheck",
    "test:smoke": "node scripts/smoke.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "cross-env": "^7.0.3",
    "tsx": "^4.20.5",
    "vite": "^5.4.21"
  }
}
